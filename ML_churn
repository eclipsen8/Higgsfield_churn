espan_days'] = (agg['last_purchase_time'] - agg['first_purchase_time']).dt.days.fillna(0)\n    return agg.drop(columns=['last_purchase_time', 'first_purchase_time'])\n\ndef get_transaction_features(tx_df, pur_df):\n    df = tx_df.merge(pur_df[['transaction_id', 'user_id']], on='transaction_id', how='inner')\n    df['failure_code'] = df['failure_code'].replace({'None': np.nan, 'NaN': np.nan, 'null': np.nan, '': np.nan})\n    agg = df.groupby('user_id').agg(\n        total_attempts=('transaction_id', 'count'),\n        failed_attempts=('failure_code', lambda x: x.notna().sum())\n    ).reset_index()\n    agg['failed_payment_ratio'] = agg['failed_attempts'] / agg['total_attempts']\n    df_sorted = df.sort_values(by=['user_id', 'transaction_id'])\n    last_tx = df_sorted.groupby('user_id').tail(1)\n    last_tx['last_payment_failed'] = last_tx['failure_code'].notna().astype(int)\n    agg = agg.merge(last_tx[['user_id', 'last_payment_failed']], on='user_id', how='left')\n    return agg\n\ndef process_huge_generations(file_path):\n    print(\"⏳ Читаем 5GB файл генераций по кусочкам (это займет 2-3 минуты)...\")\n    cols_to_use = ['user_id', 'status', 'credit_cost', 'created_at']\n    agg_chunks = []\n    \n    for chunk in pd.read_csv(file_path, usecols=cols_to_use, chunksize=2000000, low_memory=False):\n        chunk['created_at'] = pd.to_datetime(chunk['created_at'], errors='coerce')\n        grp = chunk.groupby('user_id').agg(\n            total_generations=('status', 'count'),\n            failed_generations=('status', lambda x: (x == 'failed').sum()),\n            nsfw_generations=('status', lambda x: (x == 'nsfw').sum()),\n            total_credits=('credit_cost', 'sum'),\n            last_gen_time=('created_at', 'max')\n        ).reset_index()\n        agg_chunks.append(grp)\n        print(\"■\", end=\"\")\n        \n    print(\"\\n✅ Склеиваем генерации...\")\n    full_df = pd.concat(agg_chunks)\n    final_agg = full_df.groupby('user_id').agg(\n        total_generations=('total_generations', 'sum'),\n        failed_generations=('failed_generations', 'sum'),\n        nsfw_generations=('nsfw_generations', 'sum'),\n        total_credits=('total_credits', 'sum'),\n        last_generation_time=('last_gen_time', 'max')\n    ).reset_index()\n    \n    final_agg['nsfw_ratio'] = (final_agg['nsfw_generations'] / final_agg['total_generations']).fillna(0)\n    max_time = final_agg['last_generation_time'].max()\n    final_agg['days_since_last_gen'] = (max_time - final_agg['last_generation_time']).dt.days.fillna(999)\n    return final_agg.drop(columns=['last_generation_time'])","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-05T07:02:42.319603Z","iopub.execute_input":"2026-04-05T07:02:42.320137Z","iopub.status.idle":"2026-04-05T07:02:42.336000Z","shell.execute_reply.started":"2026-04-05T07:02:42.320111Z","shell.execute_reply":"2026-04-05T07:02:42.335218Z"}},"outputs":[],"execution_count":3},{"cell_type":"code","source":"# === 1. ТОЧНЫЕ ПУТИ ===\n# (Оставила твой формат с datasets/abdanurayazbek/, если вдруг Kaggle ругнется - просто сотри эту часть)\n\ntrain_dir = \"/kaggle/input/datasets/abdanurayazbek/hack-nu-train-data/Train Data/\"\ntest_dir = \"/kaggle/input/datasets/abdanurayazbek/hack-nu-test-data/Test Data/\"\n\n# Тренировочные генерации лежат отдельно!\ntrain_gen_file = \"/kaggle/input/datasets/abdanurayazbek/hack-nu-train-users-generations/train_users_generations.csv\"\n\n# А тестовые генерации лежат внутри папки Test Data\ntest_gen_file = test_dir + \"test_users_generations.csv\" \n\n\n# === 2. ЗАГРУЗКА ТРЕЙНА ===\nprint(\"Загружаем Train...\")\ntrain_users = pd.read_csv(train_dir + \"train_users.csv\")\ntrain_purchases = pd.read_csv(train_dir + \"train_users_purchases.csv\")\ntrain_tx = pd.read_csv(train_dir + \"train_users_transaction_attempts.csv\", low_memory=False)\ntrain_quizzes = pd.read_csv(train_dir + \"train_users_quizzes.csv\", low_memory=False)\ntrain_properties = pd.read_csv(train_dir + \"train_us